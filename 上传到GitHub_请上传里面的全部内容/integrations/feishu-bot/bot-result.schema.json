{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["complete", "needs_clarification", "preflight_failed", "partial", "failed"]
    },
    "message": {
      "type": "string"
    },
    "clarification_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "note_path": {
      "type": ["string", "null"]
    },
    "audio_path": {
      "type": ["string", "null"]
    },
    "video_path": {
      "type": ["string", "null"]
    },
    "supporting_paths": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "status",
    "message",
    "clarification_questions",
    "note_path",
    "audio_path",
    "video_path",
    "supporting_paths"
  ],
  "additionalProperties": false
}
